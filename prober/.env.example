# Copy to .env and fill in. This file is committed; .env is NOT.

# Must EXACTLY match the INGEST_TOKEN secret set on the Cloudflare Worker
# (wrangler secret put INGEST_TOKEN). Generate one with:  openssl rand -hex 32
INGEST_TOKEN=replace-with-the-same-long-random-token-as-the-worker

# Optional: override the ingest URL from config.json (handy for local testing
# against `wrangler dev`, e.g. http://localhost:8787/api/ingest).
# INGEST_URL=https://status.aswincloud.com/api/ingest
