{
  "name": "home-status",
  "version": "1.0.0",
  "private": true,
  "description": "BetterStack-style live status page for a home network, hosted on Cloudflare Workers + D1.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init:local": "wrangler d1 execute status-db --file schema.sql --local",
    "db:init:remote": "wrangler d1 execute status-db --file schema.sql --remote",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "@aswincloud/auth": "^0.1.3"
  }
}
